<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Takealot Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        body {
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            background-color: #f5f5f5;
            font-family: 'Segoe UI', sans-serif;
        }

        .sidebar {
            width: 220px;
            height: 100vh;
            background-color: #0773ba;
            color: white;
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 1rem;
        }

        .sidebar img {
            width: 140px;
            height: 40px;
            margin-bottom: 0.25rem;
        }

        .sidebar hr {
            width: 100%;
            margin: 0;
        }

        .sidebar a {
            color: white;
            text-decoration: none;
            display: block;
            width: 100%;
            padding: 0.6rem 1.2rem;
            font-size: 0.75rem;
            transition: background-color 0.3s, padding-left 0.2s;
            margin-top: 10px;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background-color: rgba(255, 255, 255, 0.2);
            padding-left: 1.5rem;
        }

        .sidebar a:first-of-type {
        margin-top: 1rem;
        }

        .top-navbar {
            background-color: white;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem;
            
            border-bottom: 1px solid #ddd;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            position: fixed;
            top: 0;
            right: 0;
            left: 220px;
            z-index: 10;
        }

        .top-navbar h5 {
            margin: 0;
            font-weight: 600;
                color: #0773ba;
        }

        .top-navbar .icon-group i {
            color: dimgrey;
            font-size: 1.2rem;
            margin-left: 1rem;
            cursor: pointer;
        }

        .content {
            margin-left: 220px;
            margin-top: 60px;
            padding: 1.5rem;
        }
    </style>
</head>

<body>
    <div class="sidebar">
        <img src="~/images/takealot-alt-logo.png" alt="Takealot Logo" />
        <hr />

        <a asp-controller="Admin" asp-action="Dashboard"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" &&
                           ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
            <i class="fas fa-palette me-2"></i> Dashboard
        </a>

        <a asp-controller="Warehouse" asp-action="Index"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Warehouse" ? "active" : "")">
            <i class="fas fa-warehouse me-2"></i> Warehouse Management
        </a>

        <a asp-controller="Admin" asp-action="DriverManagement"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" &&
                           ViewContext.RouteData.Values["action"]?.ToString() == "DriverManagement" ? "active" : "")">
            <i class="fas fa-truck me-2"></i> Driver Management
        </a>

        <a asp-controller="Vehicle" asp-action="Index"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Vehicle" ? "active" : "")">
            <i class="fas fa-car me-2"></i> Vehicle Management
        </a>

        <a asp-controller="Vacancy" asp-action="Index"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Vacancy" ? "active" : "")">
            <i class="fas fa-briefcase me-2"></i> Vacancy Management
        </a>

        <a asp-controller="JobApplication" asp-action="Index"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "JobApplication" ? "active" : "")">
            <i class="fas fa-file-alt me-2"></i> Job Applications
        </a>

        <a asp-controller="Notification" asp-action="Index"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "active" : "")">
            <i class="fas fa-bell me-2"></i> Notifications
        </a>

        <a asp-controller="ActivityLog" asp-action="Index"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "ActivityLog" ? "active" : "")">
            <i class="fas fa-history me-2"></i> Activity Log
        </a>
    </div>


    <div class="top-navbar">
        <i class="fas fa-bars" style="color: #0773ba"></i>
        <h5>@ViewData["Title"]</h5>
        <div class="icon-group">
            <i class="fas fa-bell"></i>
            <i class="fas fa-user-circle"></i>
        </div>
    </div>

    <div class="content">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
