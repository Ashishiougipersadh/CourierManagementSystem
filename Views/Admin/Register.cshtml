@model TakealotDriverManagementSystem.Models.AdminRegistrationViewModel

@{
    ViewData["Title"] = "Admin Registration";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - TakealotDriverManagementSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f5f5f5;
        }

        .registration-card {
            max-width: 500px;
            margin: 50px auto;
            padding: 30px;
            background-color: #fff;
            border-radius: 10px;
            box-shadow: 0 0 15px rgba(0,0,0,0.2);
        }

            .registration-card h3 {
                margin-bottom: 1rem;
            }

            .registration-card p {
                margin-bottom: 2rem;
            }

        .form-control::placeholder {
            color: #888;
        }
    </style>
</head>
<body>
    <div class="registration-card">
        <div class="text-center mb-3">
            <img src="~/images/takealot-logo.png" style="width: 120px;" />
        </div>

        <h5 class="text-center" style="color: #258cfb"><b>Driver Management System</b></h5>
        <p class="text-center">Create your new account:</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <ul>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="row mb-3">
                <div class="col">
                    <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col">
                    <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col">
                    <input asp-for="Email" class="form-control" placeholder="Email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col">
                    <select asp-for="Role" class="form-select">
                        <option value="">Select Role</option>
                        <option value="Admin">Admin</option>
                        <option value="Driver">Driver</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col">
                    <input asp-for="ContactNumber" class="form-control" placeholder="Phone Number" />
                    <span asp-validation-for="ContactNumber" class="text-danger"></span>
                </div>
                <div class="col">
                    <input asp-for="Address" class="form-control" placeholder="Physical Address" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="col">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-3"><b>Register Account</b></button>

            <p class="text-center" style="font-size: small">
                Already have an account?
                <a asp-controller="Admin" asp-action="Login" class="text-primary text-decoration-none"><b>Login here</b></a>
            </p>
        </form>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>