@model JobApplication
@{
    ViewData["Title"] = "Application Details";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header">
            <h4>Application Details</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Position:</dt>
                <dd class="col-sm-9">@Model.Vacancy?.Name</dd>

                <dt class="col-sm-3">Date Submitted:</dt>
                <dd class="col-sm-9">@Model.DateSubmitted.ToString("dd MMM yyyy")</dd>

                <dt class="col-sm-3">Status:</dt>
                <dd class="col-sm-9">
                    <span class="badge @GetStatusBadgeClass(Model.Status)">
                        @Model.Status
                    </span>
                </dd>

                <dt class="col-sm-3">License Number:</dt>
                <dd class="col-sm-9">@Model.LicenseNumber</dd>

                @if (!string.IsNullOrEmpty(Model.ResumePath))
                {
                    <dt class="col-sm-3">Resume:</dt>
                    <dd class="col-sm-9">
                        <a href="@Model.ResumePath" target="_blank" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-download"></i> Download Resume
                        </a>
                    </dd>
                }
            </dl>
        </div>
        <div class="card-footer">
            <a asp-action="JobApplications" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Applications
            </a>
        </div>
    </div>
</div>

@functions {
    public string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Accepted" => "bg-success",
            "Rejected" => "bg-danger",
            _ => "bg-warning text-dark"
        };
    }
}