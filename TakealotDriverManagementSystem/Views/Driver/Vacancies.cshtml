@model IEnumerable<TakealotDriverManagementSystem.Models.Vacancy>

@{
    ViewData["Title"] = "Available Vacancies";
    Layout = "_DriverLayout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <div>
            <a asp-action="JobApplications" class="btn btn-outline-primary me-2">View My Applications</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            There are currently no available vacancies. Please check back later.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var vacancy in Model)
            {
                <div class="col">
                    <div class="card h-100 vacancy-card">
                        <div class="card-header bg-light">
                            <h5 class="card-title mb-0">@vacancy.Name</h5>
                        </div>
                        <div class="card-body vacancy-card-body">
                            <h6 class="card-subtitle mb-2 text-muted">
                                <i class="fas fa-warehouse"></i> @vacancy.Warehouse?.Name
                            </h6>
                            <p class="card-text">@vacancy.Description</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    <i class="fas fa-map-marker-alt"></i> @vacancy.Warehouse?.Address
                                </small>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-action="Apply" asp-controller="Driver" asp-route-id="@vacancy.Id" class="btn btn-primary">
                                Apply
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>



@section Scripts {
    <script>
        // Auto-dismiss alerts after 5 seconds
        window.setTimeout(function() {
            $(".alert").fadeTo(500, 0).slideUp(500, function(){
                $(this).remove();
            });
        }, 5000);
    </script>
}