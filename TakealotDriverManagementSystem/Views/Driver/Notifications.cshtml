@model IEnumerable<TakealotDriverManagementSystem.Models.Notification>

@{
    ViewData["Title"] = "My Notifications";
    Layout = "_DriverLayout"; // or "_AdminLayout"
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@ViewData["Title"]</h2>
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> You have no notifications.
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var notification in Model)
            {
                <a asp-action="NotificationDetails" asp-route-id="@notification.Id"
                   class="list-group-item list-group-item-action d-flex align-items-center
                         @(notification.IsRead ? "" : "bg-light")">

                    <!-- Avatar -->
                    <div class="avatar-circle bg-primary text-white fw-bold me-5">
                        t
                    </div>

                    <!-- Notification text -->
                    <div class="flex-fill text-truncate">
                        <div class="fw-bold text-truncate" style="max-width: 550px;">
                            @Html.Raw(notification.Message)
                        </div>
                        <small class="text-muted">
                            <i class="bi bi-clock"></i>
                            @notification.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        </small>
                    </div>

                    <!-- Read/Unread status -->
                    <span class="badge @(notification.IsRead ? "bg-secondary" : "bg-primary") rounded-pill">
                        @(notification.IsRead ? "Read" : "New")
                    </span>
                </a>
            }
        </div>
    }
</div>

<style>
    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }
</style>
