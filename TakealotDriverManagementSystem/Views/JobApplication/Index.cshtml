@model IEnumerable<TakealotDriverManagementSystem.Models.JobApplication>

@{
    ViewData["Title"] = "Job Applications Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mb-4" style="color: #0773ba">Job Applications Management</h1>

<table class="table table-striped table-bordered text-center align-middle">
    <thead>
        <tr>
            <th>Driver Name</th>
            <th>Vacancy Name</th>
            <th>License Number</th>
            <th>Resume</th>
            <th>Status</th>
            <th>Date Submitted</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@($"{item.User.FirstName} {item.User.LastName}")</td>
                <td>@item.Vacancy.Name</td>
                <td>@item.LicenseNumber</td>
                <td>
                    <a href="@item.ResumePath" target="_blank" class="btn btn-sm btn-primary">
                        Download
                    </a>
                </td>
                <td>@item.Status</td>
                <td>@item.DateSubmitted.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">View</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Update Status</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
